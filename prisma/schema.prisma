// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ComponentDataType {
  number
  percentage
  integer
}

enum ComponentSourceType {
  database
  api
  manual
}

enum ComponentPeriodType {
  monthly
  quarter
  semester
  yearly
}

model IKU {
  id          String          @id @default(uuid()) @db.VarChar(36)
  code        String          @unique
  name        String
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  components  IKUComponent[]
  formulas    IKUFormula[]
  iku_results IkuResult[]
  targets     IkuTarget[]
  @@map("ikus")
}


model Component {
  id          String          @id @default(uuid()) @db.VarChar(36)
  code        String          @unique
  name        String
  description String?
  dataType    ComponentDataType @map("data_type")
  sourceType  ComponentSourceType @map("source_type")
  periodType  ComponentPeriodType @default(yearly) @map("period_type")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  ikus        IKUComponent[]
  realizations ComponentRealization[]
  targets     ComponentTarget[]
  documents   ComponentDocument[]
  @@map("components")
}

model IKUComponent {
  id          String    @id @default(uuid()) @db.VarChar(36)
  iku         IKU       @relation(fields: [ikuId], references: [id])
  ikuId       String    @db.VarChar(36)
  component   Component @relation(fields: [componentId], references: [id])
  componentId String    @db.VarChar(36)

  @@unique([ikuId, componentId])
  @@map("mapping_component_iku")
}

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FormulaOperandType {
  component
  constant
  temp
}

enum FormulaOperator {
  ADD    @map("+")
  SUB    @map("-")
  MUL    @map("*")
  DIV    @map("/")
}

model IKUFormula {
  id             String               @id @default(uuid()) @db.VarChar(36)
  iku            IKU                  @relation(fields: [ikuId], references: [id])
  ikuId          String               @db.VarChar(36)
  name           String
  description    String?
  finalResultKey String               @default("RESULT")
  isActive       Boolean              @default(true) @map("is_active")
  version        Int                  @default(1)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  details        IKUFormulaDetail[]

  @@map("iku_formula")
}

model IKUFormulaDetail {
  id         String             @id @default(uuid()) @db.VarChar(36)
  formula    IKUFormula         @relation(fields: [formulaId], references: [id])
  formulaId  String             @db.VarChar(36)
  sequence   Int

  leftType   FormulaOperandType @map("left_type")
  leftValue  String             @map("left_value")

  operator   FormulaOperator

  rightType  FormulaOperandType @map("right_type")
  rightValue String             @map("right_value")

  resultKey  String             @map("result_key")

  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@map("iku_formula_detail")
  @@index([formulaId])
  @@index([sequence])
  @@unique([formulaId, sequence])
}

model ComponentRealization {
  idRealization String   @id @default(uuid()) @db.VarChar(36) @map("id")
  idComponent   String   @map("id_component")
  month         Int
  year          Int
  value         Decimal  @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  component Component @relation(fields: [idComponent], references: [id])

  @@map("component_realizations")
  @@unique([idComponent, month, year])
  @@index([idComponent])
}

model IkuResult {
  idResult        String   @id @default(uuid()) @db.VarChar(36) @map("id")
  idIku           String   @map("id_iku")
  month           Int
  year            Int
  calculatedValue Decimal  @db.Decimal(18, 4) @map("calculated_value")
  formulaVersion  String?  @map("formula_version")
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  iku    IKU   @relation(fields: [idIku], references: [id])

  @@map("iku_results")
  @@unique([idIku, month, year])
  @@index([idIku])
  @@index([year])
  @@index([month])
}

model IkuTarget {
  id         String   @id @default(uuid()) @db.VarChar(36)
  ikuId      String   @db.VarChar(36) @map("iku_id")
  year       Int
  targetQ1   Decimal? @db.Decimal(18, 4) @map("target_q1")
  targetQ2   Decimal? @db.Decimal(18, 4) @map("target_q2")
  targetQ3   Decimal? @db.Decimal(18, 4) @map("target_q3")
  targetQ4   Decimal? @db.Decimal(18, 4) @map("target_q4")
  targetYear Decimal? @db.Decimal(18, 4) @map("target_year")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  iku        IKU      @relation(fields: [ikuId], references: [id])

  @@unique([ikuId, year])
  @@map("iku_targets")
}

model ComponentTarget {
  id          String    @id @default(uuid()) @db.VarChar(36)
  componentId String    @db.VarChar(36) @map("component_id")
  year        Int
  targetQ1    Decimal?  @db.Decimal(18, 4) @map("target_q1")
  targetQ2    Decimal?  @db.Decimal(18, 4) @map("target_q2")
  targetQ3    Decimal?  @db.Decimal(18, 4) @map("target_q3")
  targetQ4    Decimal?  @db.Decimal(18, 4) @map("target_q4")
  targetYear  Decimal?  @db.Decimal(18, 4) @map("target_year")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  component   Component @relation(fields: [componentId], references: [id])

  @@unique([componentId, year])
  @@map("component_targets")
}

model Document {
  id           String   @id @default(uuid()) @db.VarChar(36)
  filename     String
  originalName String
  url          String
  mimeType     String?
  size         Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  components   ComponentDocument[]

  @@map("documents")
}

model ComponentDocument {
  id          String    @id @default(uuid()) @db.VarChar(36)
  componentId String    @db.VarChar(36) @map("component_id")
  documentId  String    @db.VarChar(36) @map("document_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  component   Component @relation(fields: [componentId], references: [id])
  document    Document  @relation(fields: [documentId], references: [id])

  @@unique([componentId, documentId])
  @@map("component_documents")
}
