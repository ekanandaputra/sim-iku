// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ComponentDataType {
  number
  percentage
  integer
}

enum ComponentSourceType {
  database
  api
  manual
}

model IKU {
  id          String          @id @default(uuid()) @db.VarChar(36)
  code        String          @unique
  name        String
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  components  IKUComponent[]
  formulas    IKUFormula[]
  iku_results IkuResult[]
  @@map("ikus")
}

model Component {
  id          String          @id @default(uuid()) @db.VarChar(36)
  code        String          @unique
  name        String
  description String?
  dataType    ComponentDataType @map("data_type")
  sourceType  ComponentSourceType @map("source_type")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  ikus        IKUComponent[]
  realizations ComponentRealization[]
  @@map("components")
}

model IKUComponent {
  id          String    @id @default(uuid()) @db.VarChar(36)
  iku         IKU       @relation(fields: [ikuId], references: [id])
  ikuId       String    @db.VarChar(36)
  component   Component @relation(fields: [componentId], references: [id])
  componentId String    @db.VarChar(36)

  @@unique([ikuId, componentId])
  @@map("mapping_component_iku")
}

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FormulaOperandType {
  component
  constant
  temp
}

enum FormulaOperator {
  ADD    @map("+")
  SUB    @map("-")
  MUL    @map("*")
  DIV    @map("/")
}

model IKUFormula {
  id             String               @id @default(uuid()) @db.VarChar(36)
  iku            IKU                  @relation(fields: [ikuId], references: [id])
  ikuId          String               @db.VarChar(36)
  name           String
  description    String?
  finalResultKey String               @default("RESULT")
  isActive       Boolean              @default(true) @map("is_active")
  version        Int                  @default(1)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  details        IKUFormulaDetail[]

  @@map("iku_formula")
}

model IKUFormulaDetail {
  id         String             @id @default(uuid()) @db.VarChar(36)
  formula    IKUFormula         @relation(fields: [formulaId], references: [id])
  formulaId  String             @db.VarChar(36)
  sequence   Int

  leftType   FormulaOperandType @map("left_type")
  leftValue  String             @map("left_value")

  operator   FormulaOperator

  rightType  FormulaOperandType @map("right_type")
  rightValue String             @map("right_value")

  resultKey  String             @map("result_key")

  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@map("iku_formula_detail")
  @@index([formulaId])
  @@index([sequence])
  @@unique([formulaId, sequence])
}

model Period {
  idPeriod      String           @id @default(uuid()) @db.VarChar(36) @map("id")
  year          Int
  periodType    PeriodType       @map("period_type")
  periodValue   Int              @map("period_value")
  periodName    String           @map("period_name")
  level         Int
  parentId      String?          @db.VarChar(36) @map("parent_id")
  parent        Period?          @relation("PeriodChildren", fields: [parentId], references: [idPeriod])
  children      Period[]         @relation("PeriodChildren")
  realizations  ComponentRealization[]
  ikuResults    IkuResult[]

  @@map("periods")
  @@unique([year, periodType, periodValue])
  @@index([parentId])
}

model ComponentRealization {
  idRealization String   @id @default(uuid()) @db.VarChar(36) @map("id")
  idComponent   String   @map("id_component")
  idPeriod      String   @db.VarChar(36) @map("id_period")
  value         Decimal  @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  period    Period    @relation(fields: [idPeriod], references: [idPeriod])
  component Component @relation(fields: [idComponent], references: [id])

  @@map("component_realizations")
  @@unique([idComponent, idPeriod])
  @@index([idPeriod])
  @@index([idComponent])
}

model IkuResult {
  idResult        String   @id @default(uuid()) @db.VarChar(36) @map("id")
  idIku           String   @map("id_iku")
  idPeriod        String   @db.VarChar(36) @map("id_period")
  calculatedValue Decimal  @db.Decimal(18, 4) @map("calculated_value")
  formulaVersion  String?  @map("formula_version")
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  iku    IKU   @relation(fields: [idIku], references: [id])
  period Period @relation(fields: [idPeriod], references: [idPeriod])

  @@map("iku_results")
  @@unique([idIku, idPeriod])
  @@index([idIku])
  @@index([idPeriod])
}

enum PeriodType {
  year
  semester
  quarter
}
