// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ComponentDataType {
  number
  percentage
  integer
}

enum ComponentSourceType {
  database
  api
  manual
}

enum ComponentPeriodType {
  monthly
  quarter
  semester
  yearly
}

enum IkuUnitType {
  percentage
  text
  number
  file
}

model IKU {
  id            String         @id @default(uuid()) @db.VarChar(36)
  code          String         @unique
  name          String
  description   String?
  isDirectInput Boolean        @default(false) @map("is_direct_input")
  unit          IkuUnitType    @default(percentage)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  components    IKUComponent[]
  formulas      IKUFormula[]
  iku_results   IkuResult[]
  targets       IkuTarget[]
  users         IkuUser[]

  @@map("ikus")
}

model Component {
  id           String                 @id @default(uuid()) @db.VarChar(36)
  code         String                 @unique
  name         String
  description  String?
  dataType     ComponentDataType?     @map("data_type")
  sourceType   ComponentSourceType?   @map("source_type")
  periodType   ComponentPeriodType    @default(yearly) @map("period_type")
  hasBreakdown Boolean                @default(false) @map("has_breakdown")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  ikus         IKUComponent[]
  realizations ComponentRealization[]
  targets      ComponentTarget[]
  documents    ComponentDocument[]
  tags         ComponentTag[]
  users        ComponentUser[]

  @@map("components")
}

model IKUComponent {
  id          String    @id @default(uuid()) @db.VarChar(36)
  iku         IKU       @relation(fields: [ikuId], references: [id])
  ikuId       String    @db.VarChar(36)
  component   Component @relation(fields: [componentId], references: [id])
  componentId String    @db.VarChar(36)

  @@unique([ikuId, componentId])
  @@map("mapping_component_iku")
}

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FormulaOperandType {
  component
  constant
  temp
  formula_ref
}

enum FormulaOperator {
  ADD @map("+")
  SUB @map("-")
  MUL @map("*")
  DIV @map("/")
}

model IKUFormula {
  id             String             @id @default(uuid()) @db.VarChar(36)
  iku            IKU                @relation(fields: [ikuId], references: [id])
  ikuId          String             @db.VarChar(36)
  name           String
  description    String?
  finalResultKey String             @default("RESULT")
  isActive       Boolean            @default(true) @map("is_active")
  isFinal        Boolean            @default(false) @map("is_final")
  version        Int                @default(1)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  details        IKUFormulaDetail[]

  @@map("iku_formula")
}

model IKUFormulaDetail {
  id        String     @id @default(uuid()) @db.VarChar(36)
  formula   IKUFormula @relation(fields: [formulaId], references: [id])
  formulaId String     @db.VarChar(36)
  sequence  Int

  leftType  FormulaOperandType @map("left_type")
  leftValue String             @map("left_value")

  operator FormulaOperator

  rightType  FormulaOperandType @map("right_type")
  rightValue String             @map("right_value")

  resultKey String @map("result_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([formulaId, sequence])
  @@index([formulaId])
  @@index([sequence])
  @@map("iku_formula_detail")
}

model ComponentRealization {
  idRealization String   @id @default(uuid()) @map("id") @db.VarChar(36)
  idComponent   String   @map("id_component")
  month         Int?
  year          Int
  value         Decimal  @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  component  Component @relation(fields: [idComponent], references: [id])
  documents  ComponentRealizationDocument[]
  breakdowns ComponentRealizationBreakdown[]

  @@unique([idComponent, month, year])
  @@index([idComponent])
  @@map("component_realizations")
}

model IkuResult {
  idResult        String   @id @default(uuid()) @map("id") @db.VarChar(36)
  idIku           String   @map("id_iku")
  month           Int
  year            Int
  calculatedValue Decimal? @map("calculated_value") @db.Decimal(18, 4)
  textValue       String?  @map("text_value") @db.Text
  documentIds     Json?    @map("document_ids")
  metadata        Json?    @map("metadata")
  formulaVersion  String?  @map("formula_version")
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  iku IKU @relation(fields: [idIku], references: [id])

  @@unique([idIku, month, year])
  @@index([idIku])
  @@index([year])
  @@index([month])
  @@map("iku_results")
}

model IkuTarget {
  id         String   @id @default(uuid()) @db.VarChar(36)
  ikuId      String   @map("iku_id") @db.VarChar(36)
  year       Int
  targetQ1   Decimal? @map("target_q1") @db.Decimal(18, 4)
  targetQ2   Decimal? @map("target_q2") @db.Decimal(18, 4)
  targetQ3   Decimal? @map("target_q3") @db.Decimal(18, 4)
  targetQ4   Decimal? @map("target_q4") @db.Decimal(18, 4)
  targetYear Decimal? @map("target_year") @db.Decimal(18, 4)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  iku IKU @relation(fields: [ikuId], references: [id])

  @@unique([ikuId, year])
  @@map("iku_targets")
}

model ComponentTarget {
  id          String   @id @default(uuid()) @db.VarChar(36)
  componentId String   @map("component_id") @db.VarChar(36)
  year        Int
  targetQ1    Decimal? @map("target_q1") @db.Decimal(18, 4)
  targetQ2    Decimal? @map("target_q2") @db.Decimal(18, 4)
  targetQ3    Decimal? @map("target_q3") @db.Decimal(18, 4)
  targetQ4    Decimal? @map("target_q4") @db.Decimal(18, 4)
  targetYear  Decimal? @map("target_year") @db.Decimal(18, 4)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  component Component @relation(fields: [componentId], references: [id])

  @@unique([componentId, year])
  @@map("component_targets")
}

model Document {
  id           String   @id @default(uuid()) @db.VarChar(36)
  filename     String
  originalName String
  url          String
  mimeType     String?
  size         Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  components ComponentDocument[]
  realizationDocuments ComponentRealizationDocument[]

  @@map("documents")
}

model ComponentDocument {
  id          String   @id @default(uuid()) @db.VarChar(36)
  componentId String   @map("component_id") @db.VarChar(36)
  documentId  String   @map("document_id") @db.VarChar(36)
  createdAt   DateTime @default(now()) @map("created_at")

  component Component @relation(fields: [componentId], references: [id])
  document  Document  @relation(fields: [documentId], references: [id])

  @@unique([componentId, documentId])
  @@map("component_documents")
}

model Tag {
  id         String         @id @default(uuid()) @db.VarChar(36)
  name       String
  color      String?        @db.VarChar(7)
  deletedAt  DateTime?      @map("deleted_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  components ComponentTag[]

  @@map("tags")
}

model ComponentTag {
  id          String   @id @default(uuid()) @db.VarChar(36)
  componentId String   @map("component_id") @db.VarChar(36)
  tagId       String   @map("tag_id") @db.VarChar(36)
  createdAt   DateTime @default(now()) @map("created_at")

  component Component @relation(fields: [componentId], references: [id])
  tag       Tag       @relation(fields: [tagId], references: [id])

  @@unique([componentId, tagId])
  @@map("component_tags")
}

model ComponentRealizationDocument {
  id            String   @id @default(uuid()) @db.VarChar(36)
  realizationId String   @map("realization_id") @db.VarChar(36)
  documentId    String   @map("document_id") @db.VarChar(36)
  createdAt     DateTime @default(now()) @map("created_at")

  realization ComponentRealization @relation(fields: [realizationId], references: [idRealization], onDelete: Cascade)
  document    Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([realizationId, documentId])
  @@map("component_realization_documents")
}

model ComponentUser {
  id          String   @id @default(uuid()) @db.VarChar(36)
  componentId String   @map("component_id") @db.VarChar(36)
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  component Component @relation(fields: [componentId], references: [id])

  @@unique([componentId, userId])
  @@map("component_users")
}

model IkuUser {
  id        String   @id @default(uuid()) @db.VarChar(36)
  ikuId     String   @map("iku_id") @db.VarChar(36)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  iku IKU @relation(fields: [ikuId], references: [id])

  @@unique([ikuId, userId])
  @@map("iku_users")
}

model Prodi {
  id         String   @id @default(uuid()) @db.VarChar(36)
  code       String   @unique
  name       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  breakdowns ComponentRealizationBreakdown[]

  @@map("prodi")
}

model ComponentRealizationBreakdown {
  id            String   @id @default(uuid()) @db.VarChar(36)
  realizationId String   @map("realization_id") @db.VarChar(36)
  prodiId       String   @map("prodi_id") @db.VarChar(36)
  value         Decimal  @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  realization ComponentRealization @relation(fields: [realizationId], references: [idRealization], onDelete: Cascade)
  prodi       Prodi                @relation(fields: [prodiId], references: [id])

  @@unique([realizationId, prodiId])
  @@index([realizationId])
  @@map("component_realization_breakdowns")
}
