generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ComponentDataType {
  number
  percentage
  integer
}

enum ComponentSourceType {
  database
  api
  manual
}

model IKU {
  id          String          @id @default(uuid()) @db.VarChar(36)
  code        String          @unique
  name        String
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  components  IKUComponent[]
  formulas    IKUFormula[]
  iku_results IkuResult[]
  @@map("ikus")
}

model Component {
  id          String          @id @default(uuid()) @db.VarChar(36)
  code        String          @unique
  name        String
  description String?
  dataType    ComponentDataType @map("data_type")
  sourceType  ComponentSourceType @map("source_type")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  ikus        IKUComponent[]
  realizations ComponentRealization[]
  @@map("components")
}

model IKUComponent {
  id          String    @id @default(uuid()) @db.VarChar(36)
  iku         IKU       @relation(fields: [ikuId], references: [id])
  ikuId       String    @db.VarChar(36)
  component   Component @relation(fields: [componentId], references: [id])
  componentId String    @db.VarChar(36)

  @@unique([ikuId, componentId])
  @@map("mapping_component_iku")
}

model User {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FormulaOperandType {
  component
  constant
  temp
}

enum FormulaOperator {
  ADD    @map("+")
  SUB    @map("-")
  MUL    @map("*")
  DIV    @map("/")
}

model IKUFormula {
  id             String               @id @default(uuid()) @db.VarChar(36)
  iku            IKU                  @relation(fields: [ikuId], references: [id])
  ikuId          String               @db.VarChar(36)
  name           String
  description    String?
  finalResultKey String               @default("RESULT")
  isActive       Boolean              @default(true) @map("is_active")
  version        Int                  @default(1)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  details        IKUFormulaDetail[]

  @@map("iku_formula")
}

model IKUFormulaDetail {
  id         String             @id @default(uuid()) @db.VarChar(36)
  formula    IKUFormula         @relation(fields: [formulaId], references: [id])
  formulaId  String             @db.VarChar(36)
  sequence   Int

  leftType   FormulaOperandType @map("left_type")
  leftValue  String             @map("left_value")

  operator   FormulaOperator

  rightType  FormulaOperandType @map("right_type")
  rightValue String             @map("right_value")

  resultKey  String             @map("result_key")

  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@map("iku_formula_detail")
  @@index([formulaId])
  @@index([sequence])
  @@unique([formulaId, sequence])
}

model Period {
  id_period      Int                 @id @default(autoincrement())
  year           Int
  period_type    PeriodType
  period_value   Int
  period_name    String
  level          Int
  parent_id      Int?
  parent         Period?             @relation("PeriodChildren", fields: [parent_id], references: [id_period])
  children       Period[]            @relation("PeriodChildren")
  realizations   ComponentRealization[]
  iku_results    IkuResult[]

  @@map("periods")
  @@unique([year, period_type, period_value])
  @@index([parent_id])
}

model ComponentRealization {
  id_realization Int      @id @default(autoincrement())
  id_component   String
  id_period      Int
  value          Decimal  @db.Decimal(18, 4)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  period    Period    @relation(fields: [id_period], references: [id_period])
  component Component @relation(fields: [id_component], references: [id])

  @@map("component_realizations")
  @@unique([id_component, id_period])
  @@index([id_period])
  @@index([id_component])
}

model IkuResult {
  id_result       Int      @id @default(autoincrement())
  id_iku          String
  id_period       Int
  calculated_value Decimal @db.Decimal(18, 4)
  formula_version String?
  calculated_at   DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  iku    IKU   @relation(fields: [id_iku], references: [id])
  period Period @relation(fields: [id_period], references: [id_period])

  @@map("iku_results")
  @@unique([id_iku, id_period])
  @@index([id_iku])
  @@index([id_period])
}

enum PeriodType {
  year
  semester
  quarter
}
